{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "config": {
      "type": "object",
      "properties": {
        "postgres_host": {
          "type": "string",
          "description": "PostgreSQL host"
        },
        "postgres_username": {
          "type": "string",
          "description": "PostgreSQL username"
        },
        "postgres_database": {
          "type": "string",
          "description": "PostgreSQL database name"
        },
        "postgres_password": {
          "type": "string",
          "description": "PostgreSQL password"
        },
        "redis_password": {
          "type": "string",
          "description": "Redis password"
        },
        "jwt_secret": {
          "type": "string",
          "description": "JWT secret for token generation"
        },
        "keycloak_admin_password": {
          "type": "string",
          "description": "Keycloak admin password"
        },
        "keycloak_client_secret": {
          "type": "string",
          "description": "Keycloak OAuth client secret"
        },
        "litellm_api_key": {
          "type": "string",
          "description": "LiteLLM API key"
        },
        "langfuse_salt": {
          "type": "string",
          "description": "Langfuse salt for password hashing"
        },
        "langfuse_nextauth_secret": {
          "type": "string",
          "description": "Langfuse NextAuth secret"
        },
        "clickhouse_password": {
          "type": "string",
          "description": "ClickHouse password"
        },
        "default_api_key": {
          "type": "string",
          "description": "Default API key for OpenHands"
        },
        "sandbox_api_key": {
          "type": "string",
          "description": "Sandbox API key"
        },
        "keycloak_realm_name": {
          "type": "string",
          "description": "Keycloak realm name"
        },
        "keycloak_provider_name": {
          "type": "string",
          "description": "Keycloak provider name"
        },
        "keycloak_client_id": {
          "type": "string",
          "description": "Keycloak OAuth client ID"
        },
        "keycloak_smtp_password": {
          "type": "string",
          "description": "Keycloak SMTP password"
        },
        "anthropic_api_key": {
          "type": "string",
          "description": "Anthropic API key for Claude models"
        },
        "openai_api_key": {
          "type": "string",
          "description": "OpenAI API key for GPT models"
        },
        "google_gemini_api_key": {
          "type": "string",
          "description": "Google Gemini API key"
        },
        "google_vertex_credentials": {
          "type": "string",
          "description": "Google Vertex AI credentials JSON"
        },
        "deepseek_api_key": {
          "type": "string",
          "description": "DeepSeek API key"
        },
        "mistral_api_key": {
          "type": "string",
          "description": "Mistral AI API key"
        },
        "azure_api_key": {
          "type": "string",
          "description": "Azure OpenAI API key"
        },
        "groq_api_key": {
          "type": "string",
          "description": "Groq API key"
        },
        "openrouter_api_key": {
          "type": "string",
          "description": "OpenRouter API key"
        },
        "custom_api_key": {
          "type": "string",
          "description": "Custom LLM API key"
        },
        "external_s3_access_key": {
          "type": "string",
          "description": "S3 access key"
        },
        "external_s3_secret_key": {
          "type": "string",
          "description": "S3 secret key"
        },
        "github_oauth_client_id": {
          "type": "string",
          "description": "GitHub OAuth client ID"
        },
        "github_oauth_client_secret": {
          "type": "string",
          "description": "GitHub OAuth client secret"
        },
        "github_app_id": {
          "type": "string",
          "description": "GitHub App ID"
        },
        "github_app_webhook_secret": {
          "type": "string",
          "description": "GitHub App webhook secret"
        },
        "github_app_private_key": {
          "type": "string",
          "description": "GitHub App private key"
        }
      },
      "required": [
        "postgres_username",
        "postgres_database",
        "postgres_password",
        "redis_password",
        "jwt_secret",
        "keycloak_admin_password",
        "keycloak_client_secret",
        "litellm_api_key",
        "langfuse_salt",
        "langfuse_nextauth_secret",
        "clickhouse_password",
        "default_api_key",
        "sandbox_api_key",
        "keycloak_realm_name",
        "keycloak_provider_name",
        "keycloak_client_id",
        "keycloak_smtp_password"
      ]
    }
  },
  "required": [
    "config"
  ]
}