# -----------------------------------------------------------------------------
# Multi Cluster - Path-Based Routing - Example Configuration
# -----------------------------------------------------------------------------
# Copy this file to terraform.tfvars and update the values.
#
# This environment creates TWO clusters:
# - Core cluster: runs UI, API, Keycloak, etc.
# - Runtime cluster: runs OpenHands agent runtimes
#
# Path-based routing uses paths on single domain:
#   - domain.com/ (main app)
#   - domain.com/api/* (runtime API)
#   - domain.com/auth/* (keycloak)
# -----------------------------------------------------------------------------

project_id       = "staging-092324"
region           = "us-central1"
runtime_region   = "us-central1"  # Can be different for geographic distribution
environment_name = "oh-multi-path"

# Domain for this environment
domain = "multi-path.example.com"

# Set to true if you want Terraform to manage DNS
create_dns_zone = false

# Cluster configuration
deletion_protection = false

# Core cluster configuration
core_enable_autopilot       = false
core_node_machine_type      = "e2-standard-4"
core_node_pool_min_count    = 1
core_node_pool_max_count    = 5
core_node_pool_initial_count = 2

# Runtime cluster configuration (optimized for agent workloads)
runtime_enable_autopilot       = false
runtime_node_machine_type      = "e2-standard-8"
runtime_node_pool_min_count    = 0
runtime_node_pool_max_count    = 20
runtime_node_pool_initial_count = 2

# Network settings
enable_private_nodes = true
master_authorized_networks = [
  {
    cidr_block   = "0.0.0.0/0"
    display_name = "All networks (restrict for production)"
  }
]

# Labels for cost tracking and organization
labels = {
  team        = "platform"
  cost-center = "engineering"
  managed-by  = "terraform"
}
